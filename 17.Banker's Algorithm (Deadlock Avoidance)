#include <stdio.h>

int main()
{
    int alloc[5][3] = {{0,1,0},{2,0,0},{3,0,2},{2,1,1},{0,0,2}};
    int max[5][3]   = {{7,5,3},{3,2,2},{9,0,2},{2,2,2},{4,3,3}};
    int avail[3] = {3,3,2};

    int need[5][3], finish[5]={0};
    int safe[5], count=0, i, j, k;

    for(i=0;i<5;i++)
        for(j=0;j<3;j++)
            need[i][j]=max[i][j]-alloc[i][j];

    while(count<5)
    {
        int found=0;

        for(i=0;i<5;i++)
        {
            if(finish[i]==0)
            {
                for(j=0;j<3;j++)
                    if(need[i][j]>avail[j])
                        break;

                if(j==3)
                {
                    for(k=0;k<3;k++)
                        avail[k]+=alloc[i][k];

                    safe[count++]=i;
                    finish[i]=1;
                    found=1;
                }
            }
        }

        if(!found)
        {
            printf("System is not in safe state\n");
            return 0;
        }
    }

    printf("Safe Sequence: ");
    for(i=0;i<5;i++)
        printf("P%d ", safe[i]);

    return 0;
}
