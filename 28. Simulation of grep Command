#include<stdio.h>
#include<string.h>

int main()
{
    FILE *fp;
    char line[100],word[20];

    printf("Enter word: ");
    scanf("%s",word);

    fp=fopen("sample.txt","r");

    while(fgets(line,100,fp))
    {
        if(strstr(line,word))
            printf("%s",line);
    }

    fclose(fp);

    return 0;
}
