#include<stdio.h>

int main()
{
    int block[20],process[20];
    int nb,np,i,j,best;

    scanf("%d",&nb);
    scanf("%d",&np);

    for(i=0;i<nb;i++)
        scanf("%d",&block[i]);

    for(i=0;i<np;i++)
        scanf("%d",&process[i]);

    for(i=0;i<np;i++)
    {
        best=-1;

        for(j=0;j<nb;j++)
        {
            if(block[j]>=process[i])
            {
                if(best==-1 || block[j]<block[best])
                    best=j;
            }
        }

        if(best!=-1)
        {
            printf("Process %d -> Block %d\n",i+1,best+1);
            block[best]-=process[i];
        }
    }
}
