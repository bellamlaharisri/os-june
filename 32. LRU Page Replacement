#include<stdio.h>

int main()
{
    int pages[50],frames[10],time[10];
    int n,f,i,j,pos,fault=0,counter=0,flag;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&pages[i]);

    scanf("%d",&f);

    for(i=0;i<f;i++)
    {
        frames[i]=-1;
        time[i]=0;
    }

    for(i=0;i<n;i++)
    {
        flag=0;

        for(j=0;j<f;j++)
        {
            if(frames[j]==pages[i])
            {
                counter++;
                time[j]=counter;
                flag=1;
            }
        }

        if(flag==0)
        {
            pos=0;

            for(j=1;j<f;j++)
                if(time[j]<time[pos])
                    pos=j;

            frames[pos]=pages[i];
            counter++;
            time[pos]=counter;
            fault++;
        }
    }

    printf("Page Faults = %d",fault);

    return 0;
}
