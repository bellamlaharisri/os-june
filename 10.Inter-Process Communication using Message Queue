#include <stdio.h>
#include <sys/ipc.h>
#include <sys/msg.h>
#include <string.h>

struct msgbuf
{
    long mtype;
    char mtext[100];
};

int main()
{
    struct msgbuf message;

    int msgid = msgget((key_t)1234, 0666 | IPC_CREAT);

    message.mtype = 1;

    printf("Enter message: ");
    scanf("%s", message.mtext);

    msgsnd(msgid, &message, sizeof(message.mtext), 0);

    printf("Message Sent: %s\n", message.mtext);

    return 0;
}
