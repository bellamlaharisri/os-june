#include<stdio.h>

int main()
{
    int n,block[20],i;

    printf("Enter number of blocks: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&block[i]);

    printf("Linked Allocation:\n");

    for(i=0;i<n-1;i++)
        printf("%d -> ",block[i]);

    printf("%d",block[n-1]);

    return 0;
}
