#include<stdio.h>

int main()
{
    int pages[50],frames[10];
    int n,f,i,j,k=0,fault=0,flag;

    printf("Enter no. of pages: ");
    scanf("%d",&n);

    printf("Enter page reference string: ");
    for(i=0;i<n;i++)
        scanf("%d",&pages[i]);

    printf("Enter no. of frames: ");
    scanf("%d",&f);

    for(i=0;i<f;i++)
        frames[i]=-1;

    for(i=0;i<n;i++)
    {
        flag=0;

        for(j=0;j<f;j++)
        {
            if(frames[j]==pages[i])
            {
                flag=1;
                break;
            }
        }

        if(flag==0)
        {
            frames[k]=pages[i];
            k=(k+1)%f;
            fault++;
        }
    }

    printf("Page Faults = %d",fault);
    return 0;
}
