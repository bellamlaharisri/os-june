#include <stdio.h>

int main()
{
    int users, files, i, j;
    char fname[20];

    printf("Enter number of users: ");
    scanf("%d", &users);

    for(i = 1; i <= users; i++)
    {
        printf("\nUser %d\n", i);

        printf("Enter number of files: ");
        scanf("%d", &files);

        printf("Enter file names:\n");

        for(j = 1; j <= files; j++)
        {
            scanf("%s", fname);
            printf("File stored: %s\n", fname);
        }
    }

    return 0;
}
