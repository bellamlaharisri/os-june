#include<stdio.h>
#include<fcntl.h>
#include<unistd.h>

int main()
{
    int fd;

    fd=open("sample.txt",O_CREAT|O_RDWR,0777);

    write(fd,"Operating System",16);

    lseek(fd,0,SEEK_SET);

    char buf[20];
    read(fd,buf,16);

    buf[16]='\0';

    printf("%s\n",buf);

    close(fd);

    return 0;
}
