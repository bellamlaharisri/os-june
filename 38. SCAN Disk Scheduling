#include<stdio.h>
#include<stdlib.h>

int main()
{
    int req[20],n,head,i,total=0;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&req[i]);

    scanf("%d",&head);

    for(i=0;i<n;i++)
    {
        total+=abs(head-req[i]);
        head=req[i];
    }

    printf("Seek Time = %d",total);

    return 0;
}
